---
import Layout from '../../layouts/Layout.astro';
import ProductCard from '../../components/ProductCard.astro';

const products = [
  {
    name: 'MIPI CSI-2 Camera Cables',
    category: 'Robotics Vision',
    description: 'High-speed 4-Lane MIPI CSI-2 cables for robot cameras and embedded vision systems.',
    specs: ['1/2/4-Lane configurable', '0.5mm & 0.4mm pitch', 'Dual-layer shielding (85%+)', '-40 to 85degC operating range'],
    price: 'From $3.50',
    href: '/products/mipi-csi2-cables',
  },
  {
    name: 'M12 Industrial Connectors',
    category: 'Industrial Automation',
    description: 'Rugged M12 circular connectors for sensors, actuators, and fieldbus communication.',
    specs: ['A/B/D/X-code options', 'IP67 / IP68 rated', '3/4/5/8/12 pin configurations', 'Cat5e / Cat6a Ethernet'],
    price: 'From $1.20',
    href: '/products/m12-industrial-connectors',
  },
  {
    name: 'GMSL / FPD-Link III Cables',
    category: 'Automotive Vision',
    description: 'SerDes cables for automotive camera systems, supporting long-distance video transmission.',
    specs: ['Up to 15m at 6Gbps', 'GMSL2 / GMSL3 / FPD-Link III', 'FAKRA / H-MTD connectors', 'Automotive grade (AEC-Q200)'],
    price: 'From $8.00',
    href: '/products',
  },
  {
    name: 'Industrial Ethernet Cables',
    category: 'Automation',
    description: 'Shielded Ethernet cables with M12 and RJ45 connectors for industrial networks.',
    specs: ['Cat5e / Cat6a / Cat7', 'M12 D-code / X-code / RJ45', 'PUR / PVC jacket options', 'IP67 rated'],
    price: 'From $4.50',
    href: '/products',
  },
  {
    name: 'Sensor &amp; Actuator Cables',
    category: 'Automation',
    description: 'Pre-assembled connection cables for proximity sensors, photoelectric sensors, and actuators.',
    specs: ['M8 / M12 connectors', 'PNP / NPN configurations', '3-wire / 4-wire / 5-wire', 'LED indicator option'],
    price: 'From $0.80',
    href: '/products',
  },
  {
    name: 'Custom Cable Assemblies',
    category: 'Custom Solutions',
    description: 'Tailored cable harness solutions built to your exact specifications and drawings.',
    specs: ['OEM/ODM supported', 'Any connector combination', 'UL/CE/RoHS certified', '2-4 week lead time'],
    price: 'Custom Quote',
    href: '/products',
  },
];
---

<Layout
  title="Products"
  description="Browse our full catalog of MIPI CSI-2 cables, M12 industrial connectors, GMSL cables, industrial Ethernet cables, and custom cable assemblies."
>
  <section class="page-header">
    <div class="container">
      <span class="badge" data-i18n="products.badge">Product Catalog</span>
      <h1 data-i18n-html="products.title"><span data-i18n="products.title1">Cables &amp; Connectors for</span><br/><span data-i18n="products.title2">Robotics and Machine Vision</span></h1>
      <p data-i18n="products.desc">Precision-manufactured cables with full technical specifications. Every product is continuity-tested before shipping.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid grid--3">
        {products.map(p => (
          <ProductCard
            name={p.name}
            category={p.category}
            description={p.description}
            specs={p.specs}
            price={p.price}
            href={p.href}
          />
        ))}
      </div>

      <div class="custom-cta card">
        <div>
          <h3 data-i18n="products.customTitle">Need something specific?</h3>
          <p data-i18n="products.customDesc">We build custom cable assemblies to your exact drawings and specifications.</p>
        </div>
        <a href="/contact" class="btn btn--primary" data-i18n="products.customBtn">Request Custom Quote</a>
      </div>
    </div>
  </section>
</Layout>

<style>
.page-header {
  background: linear-gradient(135deg, #f0f5ff 0%, #e8f4f8 100%);
  padding: 60px 0 40px;
  text-align: center;
}

.page-header h1 {
  font-size: 2.4rem;
  margin: 16px 0 12px;
}

.page-header p {
  color: var(--color-text-light);
  font-size: 1.1rem;
  max-width: 600px;
  margin: 0 auto;
}

.custom-cta {
  margin-top: 48px;
  padding: 32px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24px;
  background: var(--color-bg-alt);
  border: 1px solid var(--color-border);
}

.custom-cta h3 {
  margin-bottom: 4px;
}

.custom-cta p {
  color: var(--color-text-light);
}

@media (max-width: 640px) {
  .custom-cta {
    flex-direction: column;
    text-align: center;
  }
  .page-header h1 { font-size: 1.6rem; }
}
</style>
