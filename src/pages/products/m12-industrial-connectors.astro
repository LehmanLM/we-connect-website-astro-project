---
import Layout from '../../layouts/Layout.astro';

const specs = [
  { label: 'Connector Series', value: 'M12 circular connector (IEC 61076-2-104)' },
  { label: 'Coding Types', value: 'A-code / B-code / D-code / X-code / S-code' },
  { label: 'Pin Count', value: '3 / 4 / 5 / 8 / 12 pins' },
  { label: 'Thread Size', value: 'M12 x 1.0' },
  { label: 'Protection Rating', value: 'IP67 / IP68 / IP69K' },
  { label: 'Mating Cycles', value: '100+ cycles minimum' },
  { label: 'Operating Temp', value: '-40degC to +80degC (extended: +125degC)' },
  { label: 'Body Material', value: 'Zinc die-cast (nickel-plated) / PBT plastic' },
  { label: 'Contact Material', value: 'Gold-plated copper alloy' },
  { label: 'Cable Jacket', value: 'PUR (oil resistant) / PVC / TPE' },
  { label: 'Certifications', value: 'UL / CE / RoHS' },
];

const codingGuide = [
  { code: 'A-code', color: '#333', desc: 'Sensors, actuators, DC power. 3-5 pins.', speed: 'Up to 100 Mbps' },
  { code: 'B-code', color: '#666', desc: 'PROFIBUS DP / PA fieldbus communication.', speed: 'Up to 12 Mbps' },
  { code: 'D-code', color: '#0b63ce', desc: 'Industrial Ethernet (PROFINET, EtherCAT). 4 pins.', speed: '100 Mbps (Cat5e)' },
  { code: 'X-code', color: '#00b8a3', desc: 'Gigabit Ethernet. 8 pins, crossed pair shielding.', speed: '10 Gbps (Cat6a)' },
];
---

<Layout
  title="M12 Industrial Connectors"
  description="Rugged M12 circular connectors and cable assemblies. A/B/D/X-code options, IP67/IP68 rated, for industrial automation and robotics."
>
  <section class="page-header">
    <div class="container">
      <a href="/products" class="back-link">&larr; All Products</a>
      <span class="badge">Industrial Automation</span>
      <h1>M12 Industrial Connectors</h1>
      <p>Rugged M12 circular connectors engineered for harsh industrial environments. Available in A/B/D/X-code variants for sensors, Ethernet, and fieldbus communication.</p>
    </div>
  </section>

  <section class="section">
    <div class="container product-detail">
      <div class="product-overview card">
        <h2>Product Overview</h2>
        <p>
          M12 connectors are the industry standard for industrial automation connectivity.
          Our M12 connector cable assemblies are built to IEC 61076-2-104 standards, with
          IP67/IP68 protection ratings suitable for wet, dusty, and vibration-prone environments.
        </p>
        <p>
          We offer all common coding types (A, B, D, X, S-code) with 3 to 12 pin configurations.
          Whether you need simple sensor connections or high-speed Gigabit Ethernet for your
          robotic cell, we have the right connector specification.
        </p>
      </div>

      <h2>Coding Type Selection Guide</h2>
      <div class="coding-guide">
        {codingGuide.map(c => (
          <div class="coding-card card">
            <div class="coding-header">
              <span class="coding-badge" style={`background:${c.color}`}>{c.code}</span>
              <span class="coding-speed">{c.speed}</span>
            </div>
            <p>{c.desc}</p>
          </div>
        ))}
      </div>

      <h2>Technical Specifications</h2>
      <table class="spec-table">
        <tbody>
          {specs.map(s => (
            <tr>
              <th>{s.label}</th>
              <td>{s.value}</td>
            </tr>
          ))}
        </tbody>
      </table>

      <div class="info-grid">
        <div class="info-card card">
          <h3>Assembly Types</h3>
          <ul>
            <li><b>Overmolded</b> &mdash; Factory-molded, IP67, cost-effective</li>
            <li><b>Field-attachable</b> &mdash; DIY termination, repairable on-site</li>
            <li><b>Pigtail</b> &mdash; Open end for custom wiring</li>
            <li><b>Panel-mount</b> &mdash; For enclosure/cabinet installation</li>
            <li><b>T-splitter / Y-coupler</b> &mdash; Branch connections</li>
          </ul>
        </div>
        <div class="info-card card">
          <h3>Application Scenarios</h3>
          <ul>
            <li>Robot end-effector wiring</li>
            <li>AGV/AMR sensor connections</li>
            <li>Conveyor belt proximity sensors</li>
            <li>Industrial Ethernet networks</li>
            <li>PROFINET / EtherCAT fieldbus</li>
            <li>IP-camera outdoor installations</li>
            <li>Machine tool feedback systems</li>
          </ul>
        </div>
      </div>

      <div class="detail-cta">
        <a href="/contact" class="btn btn--primary">Request Quote</a>
        <a href="/blog/m12-connector-coding-guide" class="btn btn--outline">Read M12 Coding Guide</a>
      </div>
    </div>
  </section>
</Layout>

<style>
.page-header {
  background: linear-gradient(135deg, #f0f5ff 0%, #e8f4f8 100%);
  padding: 40px 0 36px;
}

.page-header h1 {
  font-size: 2.2rem;
  margin: 12px 0;
}

.page-header p {
  color: var(--color-text-light);
  font-size: 1.05rem;
  max-width: 640px;
}

.back-link {
  font-size: 0.9rem;
  display: inline-block;
  margin-bottom: 16px;
}

.product-detail {
  max-width: 860px;
  margin: 0 auto;
}

.product-detail h2 {
  margin-top: 48px;
  margin-bottom: 20px;
}

.product-overview {
  padding: 32px;
}

.product-overview h2 {
  margin-top: 0;
}

.product-overview p {
  margin-bottom: 16px;
}

.coding-guide {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 20px;
}

.coding-card {
  padding: 24px;
}

.coding-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12px;
}

.coding-badge {
  color: #fff;
  padding: 4px 16px;
  border-radius: 6px;
  font-weight: 700;
  font-size: 0.9rem;
}

.coding-speed {
  font-size: 0.85rem;
  color: var(--color-text-light);
  font-weight: 600;
}

.coding-card p {
  font-size: 0.92rem;
  color: var(--color-text);
}

.info-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
  gap: 24px;
  margin: 24px 0;
}

.info-card {
  padding: 28px;
}

.info-card h3 {
  margin-bottom: 16px;
}

.info-card ul {
  list-style: none;
}

.info-card li {
  padding: 6px 0;
  font-size: 0.92rem;
  border-bottom: 1px solid var(--color-border);
}

.detail-cta {
  display: flex;
  gap: 16px;
  margin-top: 48px;
}

@media (max-width: 640px) {
  .detail-cta { flex-direction: column; }
  .page-header h1 { font-size: 1.6rem; }
}
</style>
