---
import Layout from '../layouts/Layout.astro';
import ProductCard from '../components/ProductCard.astro';

const products = [
  {
    name: 'MIPI CSI-2 Camera Cables',
    category: 'Robotics Vision',
    description: 'High-speed 4-Lane MIPI CSI-2 cables for robot cameras and embedded vision systems.',
    specs: ['1/2/4-Lane configurable', '0.5mm & 0.4mm pitch', 'Dual-layer shielding (85%+)', '-40 to 85degC operating range'],
    price: 'From $3.50',
    href: '/products/mipi-csi2-cables',
  },
  {
    name: 'M12 Industrial Connectors',
    category: 'Industrial Automation',
    description: 'Rugged M12 circular connectors for sensors, actuators, and fieldbus communication.',
    specs: ['A/B/D/X-code options', 'IP67 / IP68 rated', '3/4/5/8/12 pin configurations', 'Cat5e / Cat6a Ethernet'],
    price: 'From $1.20',
    href: '/products/m12-industrial-connectors',
  },
  {
    name: 'Custom Cable Assemblies',
    category: 'Custom Solutions',
    description: 'Tailored cable harness solutions built to your exact specifications and drawings.',
    specs: ['OEM/ODM supported', 'Any connector combination', 'UL/CE/RoHS certified', '2-4 week lead time'],
    price: 'Custom Quote',
    href: '/products',
  },
];
---

<Layout
  title="Home"
  description="Specialized supplier of MIPI, GMSL, and M12 industrial cables and connectors for robotics, machine vision, and automation applications."
>
  <section class="hero">
    <div class="container hero-content">
      <span class="badge" data-i18n="home.badge">Robotics &amp; Machine Vision Cable Specialist</span>
      <h1 data-i18n-html="home.heroTitle"><span data-i18n="home.heroTitle1">The Right Cables for</span><br/><span class="gradient-text" data-i18n="home.heroTitle2">Robot Vision Systems</span></h1>
      <p class="hero-desc" data-i18n="home.heroDesc">
        We help robotics and automation companies source high-quality MIPI, GMSL, and M12
        cables with precise specifications, fast delivery, and technical expertise you can trust.
      </p>
      <div class="hero-actions">
        <a href="/products" class="btn btn--primary" data-i18n="home.browseProducts">Browse Products</a>
        <a href="/contact" class="btn btn--outline" data-i18n="home.requestQuote">Request a Quote</a>
      </div>
      <div class="hero-stats">
        <div class="stat">
          <span class="stat-num">50+</span>
          <span class="stat-label" data-i18n="home.statTypes">Cable Types</span>
        </div>
        <div class="stat">
          <span class="stat-num">2-4wk</span>
          <span class="stat-label" data-i18n="home.statLeadTime">Lead Time</span>
        </div>
        <div class="stat">
          <span class="stat-num">100%</span>
          <span class="stat-label" data-i18n="home.statTested">Tested &amp; Verified</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <h2 class="section-title" data-i18n="home.whyTitle">Why Choose Us</h2>
      <p class="section-subtitle" data-i18n="home.whySubtitle">We are not just another cable supplier. We bring engineering expertise to every order.</p>
      <div class="grid grid--3">
        <div class="feature card">
          <div class="feature-icon">
            <svg width="36" height="36" viewBox="0 0 36 36" fill="none">
              <path d="M18 4l12 6v8c0 7-5 12-12 14C11 30 6 25 6 18v-8l12-6z" stroke="currentColor" stroke-width="2" fill="none"/>
              <path d="M13 18l3 3 7-7" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h3 data-i18n="home.why1.title">Engineer-Owned</h3>
          <p data-i18n="home.why1.desc">Founded by embedded systems engineers who understand MIPI, GMSL, and signal integrity. We know what matters in your application.</p>
        </div>
        <div class="feature card">
          <div class="feature-icon">
            <svg width="36" height="36" viewBox="0 0 36 36" fill="none">
              <circle cx="18" cy="18" r="14" stroke="currentColor" stroke-width="2" fill="none"/>
              <path d="M18 10v8l5 3" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round"/>
            </svg>
          </div>
          <h3 data-i18n="home.why2.title">Fast Response</h3>
          <p data-i18n="home.why2.desc">Typical quote within 24 hours. Technical questions answered directly by engineers, not sales reps passing messages to factories.</p>
        </div>
        <div class="feature card">
          <div class="feature-icon">
            <svg width="36" height="36" viewBox="0 0 36 36" fill="none">
              <rect x="6" y="10" width="24" height="20" rx="3" stroke="currentColor" stroke-width="2" fill="none"/>
              <path d="M12 10V8a6 6 0 0112 0v2" stroke="currentColor" stroke-width="2" fill="none"/>
              <circle cx="18" cy="20" r="3" stroke="currentColor" stroke-width="2" fill="none"/>
            </svg>
          </div>
          <h3 data-i18n="home.why3.title">Quality Verified</h3>
          <p data-i18n="home.why3.desc">Every cable is continuity-tested and inspected before shipping. UL, CE, and RoHS compliant materials available on request.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="section-title" data-i18n="home.featuredTitle">Featured Products</h2>
      <p class="section-subtitle" data-i18n="home.featuredSubtitle">Precision cables for robotics, automation, and machine vision applications.</p>
      <div class="grid grid--3">
        {products.map(p => (
          <ProductCard
            name={p.name}
            category={p.category}
            description={p.description}
            specs={p.specs}
            price={p.price}
            href={p.href}
          />
        ))}
      </div>
      <div style="text-align: center; margin-top: 40px;">
        <a href="/products" class="btn btn--outline" data-i18n="home.viewAllProducts">View All Products</a>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <h2 class="section-title" data-i18n="home.industriesTitle">Industries We Serve</h2>
      <div class="industries">
        <div class="industry-tag">Robotics &amp; AGV</div>
        <div class="industry-tag">Machine Vision</div>
        <div class="industry-tag">Industrial Automation</div>
        <div class="industry-tag">Automotive Camera</div>
        <div class="industry-tag">Drones &amp; UAV</div>
        <div class="industry-tag">Smart Surveillance</div>
        <div class="industry-tag">Medical Imaging</div>
        <div class="industry-tag">University Research</div>
      </div>
    </div>
  </section>

  <section class="section cta-section">
    <div class="container">
      <div class="cta-box">
        <h2 data-i18n="home.ctaTitle">Need help selecting the right cable?</h2>
        <p data-i18n="home.ctaDesc">Tell us about your application and our engineers will recommend the best solution.</p>
        <a href="/contact" class="btn btn--primary" data-i18n="home.ctaBtn">Get a Free Consultation</a>
      </div>
    </div>
  </section>
</Layout>

<style>
.hero {
  background: linear-gradient(135deg, #f0f5ff 0%, #e8f4f8 100%);
  padding: 80px 0 60px;
}

.hero-content {
  text-align: center;
  max-width: 760px;
}

.hero h1 {
  font-size: 3rem;
  margin: 20px 0;
}

.gradient-text {
  background: linear-gradient(90deg, var(--color-primary), var(--color-accent));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.hero-desc {
  font-size: 1.15rem;
  color: var(--color-text-light);
  margin-bottom: 32px;
}

.hero-actions {
  display: flex;
  gap: 16px;
  justify-content: center;
  margin-bottom: 56px;
}

.hero-stats {
  display: flex;
  gap: 48px;
  justify-content: center;
}

.stat {
  text-align: center;
}

.stat-num {
  display: block;
  font-size: 2rem;
  font-weight: 800;
  color: var(--color-primary);
}

.stat-label {
  font-size: 0.9rem;
  color: var(--color-text-light);
}

.feature {
  padding: 32px;
}

.feature-icon {
  color: var(--color-primary);
  margin-bottom: 20px;
}

.feature h3 {
  margin-bottom: 10px;
}

.feature p {
  color: var(--color-text-light);
  font-size: 0.95rem;
}

.industries {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  justify-content: center;
}

.industry-tag {
  background: #fff;
  border: 1px solid var(--color-border);
  border-radius: 24px;
  padding: 10px 24px;
  font-size: 0.95rem;
  font-weight: 500;
  color: var(--color-text);
  transition: all 0.2s;
}

.industry-tag:hover {
  border-color: var(--color-primary);
  color: var(--color-primary);
}

.cta-section {
  background: var(--color-bg-alt);
}

.cta-box {
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
  border-radius: var(--radius-lg);
  padding: 56px;
  text-align: center;
}

.cta-box h2 {
  color: #fff;
  margin-bottom: 12px;
}

.cta-box p {
  color: rgba(255, 255, 255, 0.85);
  font-size: 1.1rem;
  margin-bottom: 28px;
}

.cta-box .btn--primary {
  background: #fff;
  color: var(--color-primary);
}

.cta-box .btn--primary:hover {
  background: var(--color-dark);
  color: #fff;
}

@media (max-width: 768px) {
  .hero h1 { font-size: 2rem; }
  .hero-stats { flex-wrap: wrap; gap: 24px; }
  .hero-actions { flex-direction: column; align-items: center; }
  .cta-box { padding: 32px 20px; }
}
</style>
