---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { translations } from '../i18n/translations.js';

const { title, description, publishDate, readTime, tag } = Astro.props;
const translationsJson = JSON.stringify(translations);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | VisionCable Supply</title>
    {description && <meta name="description" content={description} />}
  </head>
  <body>
    <Header />
    <main>
      <article class="blog-post">
        <div class="container">
          <a href="/blog" class="back-link" data-i18n="blog.back">&larr; Back to Blog</a>
          <div class="blog-meta-bar">
            {tag && <span class="blog-post-tag">{tag}</span>}
            <span class="blog-post-date"><span data-i18n="blog.published">Published</span> {publishDate}</span>
            <span class="blog-post-read">{readTime} <span data-i18n="blog.minRead">min read</span></span>
          </div>
          <slot />

          <div class="blog-cta card">
            <h3 data-i18n="blog.needHelp">Need cables or technical advice?</h3>
            <a href="/contact" class="btn btn--primary" data-i18n="blog.contactUs">Contact us</a>
          </div>
        </div>
      </article>
    </main>
    <Footer />

    <script is:inline define:vars={{ translationsJson }}>
      const translations = JSON.parse(translationsJson);

      function applyLang(lang) {
        if (!translations[lang]) return;
        document.documentElement.lang = lang;

        document.querySelectorAll('[data-i18n]').forEach((el) => {
          const key = el.getAttribute('data-i18n');
          const text = translations[lang][key];
          if (text) el.textContent = text;
        });

        document.querySelectorAll('[data-i18n-placeholder]').forEach((el) => {
          const key = el.getAttribute('data-i18n-placeholder');
          const text = translations[lang][key];
          if (text) el.setAttribute('placeholder', text);
        });

        document.querySelectorAll('.lang-btn').forEach((btn) => {
          btn.classList.toggle('active', btn.dataset.lang === lang);
        });

        document.querySelectorAll('.i18n-content').forEach((el) => {
          el.style.display = el.dataset.lang === lang ? '' : 'none';
        });

        localStorage.setItem('site-lang', lang);
      }

      document.addEventListener('DOMContentLoaded', () => {
        const savedLang = localStorage.getItem('site-lang') || 'en';
        applyLang(savedLang);

        document.querySelectorAll('.lang-btn').forEach((btn) => {
          btn.addEventListener('click', () => {
            applyLang(btn.dataset.lang);
          });
        });
      });
    </script>
  </body>
</html>

<style>
.blog-post {
  max-width: 820px;
  margin: 0 auto;
  padding: 40px 24px 60px;
}

.back-link {
  display: inline-block;
  margin-bottom: 24px;
  font-size: 0.9rem;
}

.blog-meta-bar {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-bottom: 16px;
  flex-wrap: wrap;
}

.blog-post-tag {
  background: var(--color-bg-alt);
  color: var(--color-primary);
  padding: 4px 12px;
  border-radius: 6px;
  font-size: 0.8rem;
  font-weight: 600;
}

.blog-post-date,
.blog-post-read {
  font-size: 0.85rem;
  color: var(--color-text-light);
}

.blog-cta {
  margin-top: 48px;
  padding: 32px;
  text-align: center;
  background: var(--color-bg-alt);
  border: 1px solid var(--color-border);
}

.blog-cta h3 {
  margin-bottom: 16px;
}

:global(.blog-post-body h1) {
  font-size: 2rem;
  margin-bottom: 8px;
}

:global(.blog-post-body h2) {
  margin-top: 2.5em;
  margin-bottom: 0.5em;
}

:global(.blog-post-body h3) {
  margin-top: 2em;
  margin-bottom: 0.5em;
}

:global(.blog-post-body p) {
  margin-bottom: 1.2em;
  line-height: 1.8;
}

:global(.blog-post-body ul),
:global(.blog-post-body ol) {
  margin-bottom: 1.2em;
  padding-left: 1.5em;
}

:global(.blog-post-body li) {
  margin-bottom: 0.5em;
  line-height: 1.8;
}

:global(.blog-post-body table) {
  width: 100%;
  border-collapse: collapse;
  margin: 1.5em 0;
}

:global(.blog-post-body th),
:global(.blog-post-body td) {
  padding: 10px 16px;
  border: 1px solid var(--color-border);
  text-align: left;
}

:global(.blog-post-body th) {
  background: var(--color-bg-alt);
  font-weight: 600;
}

:global(.blog-post-body pre) {
  background: var(--color-dark);
  color: #e2e8f0;
  padding: 20px;
  border-radius: 8px;
  overflow-x: auto;
  margin: 1.5em 0;
}

:global(.blog-post-body code) {
  font-family: var(--font-mono);
  font-size: 0.9em;
}

:global(.blog-post-body hr) {
  border: none;
  border-top: 1px solid var(--color-border);
  margin: 2em 0;
}

:global(.blog-post-body strong) {
  font-weight: 700;
  color: var(--color-dark);
}
</style>
