---
const { name, category, description, specs, price, href } = Astro.props;
---

<a href={href} class="product-card card">
  <div class="product-icon">
    <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
      <rect x="6" y="18" width="36" height="12" rx="3" stroke="currentColor" stroke-width="2" fill="none"/>
      <line x1="6" y1="24" x2="2" y2="24" stroke="currentColor" stroke-width="2"/>
      <line x1="42" y1="24" x2="46" y2="24" stroke="currentColor" stroke-width="2"/>
      <rect x="14" y="14" width="6" height="20" rx="1" fill="currentColor" opacity="0.3"/>
      <rect x="28" y="14" width="6" height="20" rx="1" fill="currentColor" opacity="0.3"/>
    </svg>
  </div>
  <div class="product-body">
    <span class="product-category">{category}</span>
    <h3>{name}</h3>
    <p>{description}</p>
    {specs && (
      <ul class="product-specs">
        {specs.map((s: string) => <li>{s}</li>)}
      </ul>
    )}
    <div class="product-footer">
      <span class="product-price">{price}</span>
      <span class="product-link">View Details &rarr;</span>
    </div>
  </div>
</a>

<style>
.product-card {
  display: flex;
  text-decoration: none;
  color: inherit;
  padding: 28px;
  gap: 20px;
}

.product-card:hover {
  text-decoration: none;
  color: inherit;
}

.product-icon {
  color: var(--color-primary);
  flex-shrink: 0;
}

.product-body {
  flex: 1;
}

.product-category {
  display: inline-block;
  color: var(--color-accent);
  font-size: 0.78rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin-bottom: 6px;
}

.product-body h3 {
  font-size: 1.15rem;
  margin-bottom: 8px;
}

.product-body p {
  font-size: 0.92rem;
  color: var(--color-text-light);
  margin-bottom: 12px;
}

.product-specs {
  list-style: none;
  margin-bottom: 16px;
}

.product-specs li {
  font-size: 0.85rem;
  color: var(--color-text-light);
  padding-left: 16px;
  position: relative;
}

.product-specs li::before {
  content: '';
  position: absolute;
  left: 0;
  top: 10px;
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--color-accent);
}

.product-footer {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  justify-content: space-between;
  align-items: center;
}

@media (max-width: 768px) {
  .product-card {
    flex-direction: column;
    padding: 22px;
    gap: 14px;
  }
  .product-icon svg {
    width: 40px;
    height: 40px;
  }
}

.product-price {
  font-weight: 700;
  color: var(--color-dark);
  font-size: 1.05rem;
}

.product-link {
  font-size: 0.9rem;
  font-weight: 600;
  color: var(--color-primary);
}
</style>
